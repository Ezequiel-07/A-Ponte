rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default rule: Allow read/write access for all users if they are signed in.
    // WARNING: This is insecure for production. You should secure your data
    // before launching your app.
    // For more information, see: https://firebase.google.com/docs/firestore/security/get-started
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
